@model IEnumerable<Blog.ViewModel.UserRoleViewModel>

@{
    ViewData["Title"] = "使用者權限管理";
    Layout = "_Layout";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-people-fill"></i> 使用者權限管理</h2>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Email (帳號)</th>
                        <th>目前身分</th>
                        <th>狀態</th>
                        <th class="text-end pe-4">操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4">@user.Email</td>

                            <td>
                                @if (user.IsAdmin)
                                {
                                    <span class="badge bg-danger rounded-pill">管理員</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary rounded-pill">一般會員</span>
                                }
                            </td>

                            <td>
                                @if (user.IsMuted)
                                {
                                    <span class="badge bg-warning text-dark border border-warning">🚫 已禁言</span>
                                }
                                else
                                {
                                    <span class="badge bg-success rounded-pill">正常</span>
                                }
                            </td>

                            <td class="text-end pe-4">
                                <div class="btn-group" role="group">

                                    <form asp-controller="ManageUser" asp-action="ToggleAdmin" method="post" class="d-inline">
                                        <input type="hidden" name="userId" value="@user.UserId" />
                                        @if (user.IsAdmin)
                                        {
                                            // 如果是超級管理員，不顯示降級按鈕 (保護)
                                            if (user.Email == "admin@blog.com")
                                            {
                                                <button type="button" class="btn btn-sm btn-secondary" disabled>最高權限</button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="btn btn-sm btn-outline-dark" onclick="return confirm('確定降級？')">降級</button>
                                            }
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn btn-sm btn-outline-success" onclick="return confirm('確定升級？')">升級</button>
                                        }
                                    </form>

                                    <span class="mx-1"></span>

                                    @if (user.Email == "admin@blog.com")
                                    {
                                        <button class="btn btn-sm btn-light text-muted border" disabled title="無法對最高權限者操作">
                                            <i class="bi bi-shield-lock-fill"></i> 豁免
                                        </button>
                                    }
                                    else if (user.Email == User.Identity.Name)
                                    {
                                        <span class="badge bg-light text-dark border">你自己</span>
                                    }
                                    else
                                    {
                                        <form asp-controller="ManageUser" asp-action="ToggleMute" method="post" class="d-inline">
                                            <input type="hidden" name="userId" value="@user.UserId" />

                                            @if (user.IsMuted)
                                            {
                                                <button type="submit" class="btn btn-sm btn-success" onclick="return confirm('確定要解除禁言嗎？')">
                                                    <i class="bi bi-mic-fill"></i> 解除
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('確定要禁言此用戶嗎？')">
                                                    <i class="bi bi-mic-mute-fill"></i> 禁言
                                                </button>
                                            }
                                        </form>
                                    }

                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>