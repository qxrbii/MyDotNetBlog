@model Blog.Models.Posts

@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-5 mb-5">
    <div class="row">

        <aside class="col-lg-4 mb-4">
            <div class="sticky-top" style="top: 2rem; z-index: 1;">

                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">關於作者</h5>
                        <div class="d-flex align-items-center mb-3">
                            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                                <i class="bi bi-person-fill fs-4"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 fw-bold">@(Model.DisplayAuther)</h6>
                                <small class="text-muted">技術部落格寫手</small>
                            </div>
                        </div>
                        <p class="card-text small text-secondary">
                            30歲想最後放手博看看
                        </p>
                    </div>
                </div>

                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body">
                        <h5 class="card-title fw-bold mb-3">功能選單</h5>
                        <div class="d-grid gap-2">
                            <a asp-action="Index" class="btn btn-outline-primary">
                                <i class="bi bi-arrow-left"></i> 返回文章列表
                            </a>
                            <button class="btn btn-outline-secondary" onclick="window.print()">
                                <i class="bi bi-printer"></i> 列印此文章
                            </button>
                        </div>
                    </div>
                </div>

                @await Component.InvokeAsync("SideBar")

            </div>
        </aside>

        <main class="col-lg-8">
            <article class="card border-0 shadow-sm">
                <div class="card-body p-4 p-md-5">

                    <header class="mb-4 border-bottom pb-4">
                        @if (Model.Category != null)
                        {
                            <span class="badge bg-primary bg-opacity-10 text-primary mb-2">
                                @Model.Category.Name
                            </span>
                        }

                        <h1 class="fw-bolder mb-3 display-5">@Model.Title</h1>

                        <div class="text-muted fst-italic d-flex flex-wrap align-items-center gap-3">
                            <span><i class="bi bi-calendar3"></i> @Model.PublishDate.ToString("yyyy-MM-dd")</span>
                            <span><i class="bi bi-person"></i> @(Model.DisplayAuther ?? "匿名")</span>
                            <span><i class="bi bi-eye"></i> @Model.ViewCount 瀏覽</span>
                        </div>
                    </header>

                    @if (!string.IsNullOrEmpty(Model.Excerpt))
                    {
                        <div class="p-4 mb-5 bg-light rounded-3 border-start border-4 border-primary">
                            <h5 class="fw-bold text-primary mb-2">
                                <i class="bi bi-chat-quote-fill me-2"></i>摘要
                            </h5>
                            <p class="mb-0 text-secondary fst-italic fs-5">
                                @Model.Excerpt
                            </p>
                        </div>
                    }

                    @if (Model.Images != null && Model.Images.Any())
                    {
                        <figure class="mb-5">
                            <img class="img-fluid rounded shadow-sm w-100" src="@Model.Images" alt="封面圖" />
                        </figure>
                    }

                    <section class="post-content fs-5 lh-lg text-break">
                        @Html.Raw(Model.Content)
                    </section>
                    <hr />
                    <h4>留言回覆</h4>

                    @if (User.Identity.IsAuthenticated)
                    {
                        @* 登入後才顯示輸入框 *@
                        <form asp-controller="Post" asp-action="AddComment" method="post">
                            <input type="hidden" name="PostId" value="@Model.Id" />
                            <div class="mb-3">
                                <textarea name="Content" class="form-control" rows="3" placeholder="想說些什麼嗎？" required></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary">送出留言</button>
                        </form>
                    }
                    else
                    {
                        <p><a asp-controller="Account" asp-action="Login">登入</a> 後即可留言</p>
                    }

                    <div class="mt-4">
                        @foreach (var comment in Model.Comments.OrderByDescending(c => c.CreatedDate))
                        {
                            <div class="card mb-3 border-0 shadow-sm">
                                <div class="card-body">
                                    <h6 class="card-subtitle mb-2 text-primary fw-bold">@comment.User.UserName</h6>
                                    <p class="card-text">@comment.Content</p>
                                    <p class="text-muted small">@comment.CreatedDate.ToString("yyyy-MM-dd HH:mm")</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </article>

            <div class="mt-4 d-flex justify-content-between">
            </div>
        </main>

    </div>
</div>

<style>
    /* 強制處理文章內容裡的圖片 */
    .post-content img {
        /* 1. 寬度最大 100%，不會撐破手機版面 */
        max-width: 100% !important;
        /* 2. 高度自動，保持比例不變形 */
        height: auto !important;
        /* 3. 讓圖片有點圓角，比較好看 */
        border-radius: 8px;
        /* 4. 上下留白 */
        margin-top: 1rem;
        margin-bottom: 1rem;
        /* 5. 確保圖片本身是區塊元素，避免文字排版怪異 */
        display: block;
    }

    /* 處理 CKEditor 可能產生的 figure 標籤 */
    .post-content figure {
        margin: 0 0 1rem 0;
        max-width: 100% !important;
    }

    /* 處理 CKEditor 的圖片說明文字 */
    .post-content figcaption {
        text-align: center;
        color: #6c757d;
        font-size: 0.9rem;
        margin-top: 0.5rem;
    }

    /* 處理 iframe (例如嵌入 YouTube) 的自適應 */
    .post-content iframe {
        max-width: 100%;
        border-radius: 8px;
    }

    /* 文字排版優化 */
    .post-content h2 {
        margin-top: 2rem;
        font-weight: bold;
        border-left: 5px solid #0d6efd; /* 左側藍條裝飾 */
        padding-left: 1rem;
    }

    .post-content h3 {
        margin-top: 1.5rem;
        font-weight: bold;
    }

    .post-content p {
        margin-bottom: 1.2rem;
        text-align: justify; /* 左右對齊 (選擇性) */
    }
</style>