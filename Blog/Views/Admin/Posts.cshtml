@model IEnumerable<Blog.Dtos.AdminPostListDto>

@{
    ViewData["Title"] = "文章管理";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>文章管理</h3>
        <a asp-action="CreatePost" class="btn btn-success"><i class="bi bi-plus-lg"></i> 新增文章</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0" style="table-layout: fixed;">
                <thead class="table-light">
                    <tr>
                        <th style="width: 100px;">作者</th>
                        <th style="width: 20%;">標題</th>
                        <th style="width: 20%;">網址代稱 (Slug)</th>
                        <th style="width: 100px;">狀態</th>
                        <th style="width: 120px;">分類</th>
                        <th style="width: 120px;">發布日</th>
                        <th style="width: 80px;">瀏覽</th>
                        <th class="text-end">操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="fw-bold">@item.Author</span></td>

                            <td class="text-truncate" title="@item.Title">
                                @item.Title
                            </td>

                            <td class="text-truncate text-muted small" title="@item.Slug">
                                /Post/@item.Slug
                            </td>

                            <td>
                                @if (item.PublishDate <= DateTime.Now)
                                {
                                    <span class="badge bg-success">已發布</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">排程中</span>
                                }
                            </td>

                            <td><span class="badge bg-secondary">@item.CategoryName</span></td>
                            <td>@item.PublishDate.ToString("yyyy/MM/dd")</td>
                            <td>@item.ViewCount</td>

                            <td class="text-end">
                                <a asp-action="EditPost"
                                   asp-route-slug="@item.Slug"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                <form asp-action="DeletePost"
                                      asp-route-slug="@item.Slug"
                                      method="post"
                                      class="d-inline"
                                      onsubmit="return confirm('確定要刪除這篇文章嗎？此動作無法復原！');">

                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="刪除文章">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>