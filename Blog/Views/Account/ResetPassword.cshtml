@model Blog.ViewModel.ResetPasswordViewModel

<h2>重設您的密碼</h2>

<div asp-validation-summary="All" class="text-danger"></div>

<form asp-action="ResetPassword" method="post">
    <input type="hidden" asp-for="Email" />
    <input type="hidden" asp-for="Token" />

    <div class="form-group mb-3">
        <label asp-for="Password">新密碼</label>
        <div class="input-group">
            <input asp-for="Password" class="form-control" type="password" id="newPassword" />
            <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('newPassword', 'icon1')">
                <i id="icon1" class="bi bi-eye"></i>
            </button>
        </div>
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="ConfirmPassword">確認新密碼</label>
        <div class="input-group">
            <input asp-for="ConfirmPassword" class="form-control" type="password" id="confirmPassword" />
            <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('confirmPassword', 'icon2')">
                <i id="icon2" class="bi bi-eye"></i>
            </button>
        </div>
        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">送出修改</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function togglePassword(inputId, iconId) {
            var input = document.getElementById(inputId);
            var icon = document.getElementById(iconId);

            if (input.type === "password") {
                // 變成明碼
                input.type = "text";
                // 切換圖示為「斜線眼睛」(隱藏的意思)
                icon.classList.remove("bi-eye");
                icon.classList.add("bi-eye-slash");
            } else {
                // 變回密碼
                input.type = "password";
                // 切換圖示為「眼睛」(顯示的意思)
                icon.classList.remove("bi-eye-slash");
                icon.classList.add("bi-eye");
            }
        }
    </script>
}