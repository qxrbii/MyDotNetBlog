@model IEnumerable<PostListDto>

<div class="d-flex justify-content-between mb-3 align-items-center">
    <h4 class="fw-bold m-0">文章列表</h4>
    <div class="btn-group shadow-sm">
        <button class="btn btn-sm btn-light border" onclick="setView('card')"><i class="bi bi-grid"></i></button>
        <button class="btn btn-sm btn-light border" onclick="setView('list')"><i class="bi bi-list"></i></button>
    </div>
</div>

<div id="post-container" class="row row-cols-1 row-cols-md-2 g-4">
    @foreach (var item in Model)
    {
        <div class="col post-item">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="text-primary small fw-bold mb-1"># @item.CategoryName</div>
                    <h5 class="card-title fw-bold">@item.Title</h5>
                    <p class="text-muted" style="font-size: 0.8rem;">@item.PublishDate.ToShortDateString() · @item.DisplayAuther</p>
                    <span><i class="bi bi-eye"></i> @item.ViewCount 次瀏覽</span>
                    <p class="card-text text-secondary">@item.Excerpt</p>
                    <a asp-controller="Post"
                       asp-action="Details"
                       asp-route-slug="@item.Slug"
                       class="text-decoration-none">
                        繼續閱讀 &rarr;
                    </a>
                </div>
            </div>
        </div>
    }
</div>
